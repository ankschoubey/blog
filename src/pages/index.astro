---
import Layout from '~/layouts/PageLayout.astro';

import Header from '~/components/widgets/Header.astro';
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import Steps from '~/components/widgets/Steps.astro';
import BlogLatestPosts from '~/components/widgets/BlogLatestPosts.astro';
import { getPermalink } from '~/utils/permalinks';
import { headerData } from '~/navigation';
import ankushLinks from '~/content/ankushLinks';

const metadata = {
	title: 'Ankush Choubey | Startup Build Partner',
	description: 'Architecture-first development for serious founders. Launch your SaaS in 5-8 weeks with production-ready code.',
};

let topHeaderActions = [
	{
		variant: 'primary',
		target: '_blank',
		text: 'Start a Project',
		icon: 'tabler:brand-whatsapp',
		href: ankushLinks.socialMedia.whatsapp,
	},
	{
		variant: 'secondary',
		text: 'View Work',
		href: '#work',
	},
];

var modifiedHeaderDate = {
	...headerData,
	links: [],
	actions: [
		{
			text: 'Search',
			icon: 'tabler:search',
			variant: 'primary',
			href: '/search',
		},
	],
};
---

<Layout metadata={metadata}>
	<Fragment slot="announcement"></Fragment>
	<Fragment slot="header">
		<Header {...modifiedHeaderDate} />
	</Fragment>

	<Hero
		id="hero"
		title="Ankush Choubey"
		taglineInverted={true}
		tagline="Java Full Stack Developer (Backend Heavy)"
		actions={topHeaderActions}
	>
		<Fragment slot="subtitle">
			8 years of experience working with Spring Boot and React.<br /><br />
			Helping you build <a class="font-bold text-blue-700" href="/clean-code">clean</a>, <a
				class="font-bold text-blue-700"
				href="/tdd">bug-free</a
			>, scalable software <a class="font-bold text-blue-700" href="/cd">fast</a>!
			<br /><br />
			<!-- <span class="font-bold"><a class="text-blue-700 font-bold" href="https://www.linkedin.com/in/ankushchoubey/">🇮🇳 Hiring</a>: If you are looking for a remote backend-java developer role in India?</span> -->
			<br />
			<!-- <span class="highlight text-accent dark:text-white"> </span>
       I have five years of experience as a full-stack developer, with a focus on developing microservices, implementing
      test-first development practices, writing clean code, and delivering customer and business-oriented solutions.
      <br /> -->
			<!-- Through this blog, I share my insights and ideas on software development philosophy and best practices to help
      fellow developers create high-quality software products. My goal is to help you write 🧹 clean & 🐞 bug-free code
      every time and support you in swiftly delivering your 👨🏻‍💻 code to production! Hire me for consulting, speaking and
      developer roles by contacting me on LinkedIn logo. -->
		</Fragment>
	</Hero>

	<Features3
		id="value-props"
		title="What you get"
		items={[
			{
				title: 'Architecture First',
				description: 'We plan before we code. Scalable foundations from day one, not patches later.',
			},
			{
				title: 'Feature Pruning',
				description: 'Cut what doesn\'t matter. Focus on what users actually need in version one.',
			},
			{
				title: 'CTO-Level Thinking',
				description: 'Strategic guidance, not just code. You get a technical partner, not a coder.',
			},
		]}
	>
		<Fragment slot="bg">
			<div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
		</Fragment>
	</Features3>

	<Steps
		id="process"
		title="The Process"
		subtitle="From idea to production in 8 weeks"
		items={[
			{
				title: 'Week 1: Architecture Sprint',
				description: 'Scope refinement, business model clarity, feature pruning, tech stack decision, 6-12 month roadmap.',
			},
			{
				title: 'Weeks 2-7: Engineering',
				description: 'Responsive frontend, production-grade backend, authentication, payments, clean database design.',
			},
			{
				title: 'Production Launch',
				description: 'Cloud deployment, domain setup, dev/prod separation, monitoring basics, documentation.',
			},
			{
				title: '30-Day Post-Launch Support',
				description: 'Bug fixes, light refinements, strategic advice, scaling discussions, hiring roadmap.',
			},
		]}
	>
		<Fragment slot="bg">
			<div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
		</Fragment>
	</Steps>

	<Content
		id="work"
		columns={2}
		image={{
			src: 'profile.PNG',
			alt: 'Svaaya Platform',
		}}
	>
		<Fragment slot="content">
			<h3 class="mb-4 text-2xl font-bold tracking-tight dark:text-white sm:text-3xl">Case Study: Svaaya</h3>
			<p class="mb-4">Ashay came to me with a strong idea. But the scope was big. Really big.</p>
			<p class="mb-4">Instead of jumping into development, we structured it properly:</p>
			<ul class="list-disc pl-6 mb-4 space-y-2">
				<li>Defined the core flows</li>
				<li>Removed unnecessary features</li>
				<li>Designed architecture around long-term growth</li>
			</ul>
			<p class="mb-4">Built fully within 4 months — scope was larger than a typical MVP. Now when he shows the product to people, they consistently appreciate what's been built. We're continuing to expand it feature by feature.</p>
			<p class="font-semibold">That's the difference between building something… and building it properly.</p>
		</Fragment>

		<Fragment slot="bg">
			<div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
		</Fragment>
	</Content>

	<Testimonials
		id="testimonials"
		title="What others say"
		testimonials={[
			{
				testimonial: `Ankush thinks about design upfront and breaks complex problems into clear, manageable steps.`,
				name: 'VP of Engineering',
				job: 'MNC Company',
			},
			{
				testimonial: `You can trust him with complex systems. He evaluates multiple approaches before deciding.`,
				name: 'Principal Architect',
				job: 'MNC Company',
			},
			{
				testimonial: `He consistently builds reusable, clean components that reduce long-term maintenance.`,
				name: 'Technical Lead',
				job: 'Product Company',
			},
		]}
	/>

	<BlogLatestPosts
		id="tech-blog"
		tag="technical"
		title="Technical Insights"
		information="Thoughts on architecture, development, and building products."
		linkText="Read More"
		linkUrl={getPermalink('technical', 'tag')}
	>
		<Fragment slot="bg">
			<div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
		</Fragment>
	</BlogLatestPosts>

	<Content
		id="life"
		columns={1}
	>
		<Fragment slot="content">
			<p class="text-center text-muted dark:text-gray-400">
				Outside work: Boxing, Running, Gita philosophy —
				<a href={getPermalink('non-technical', 'tag')} class="text-blue-700 dark:text-blue-400 hover:underline">Life Blog</a>
			</p>
		</Fragment>

		<Fragment slot="bg">
			<div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
		</Fragment>
	</Content>

	<CallToAction
		id="cta"
		title="Ready to build properly?"
		subtitle="Let\'s discuss your project. Serious founders only."
		actions={[
			{
				variant: 'primary',
				text: 'Let\'s Talk',
				icon: 'tabler:brand-whatsapp',
				href: ankushLinks.socialMedia.whatsapp,
			},
		]}
	/>
</Layout>
